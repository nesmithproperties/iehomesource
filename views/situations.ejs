<%
var title = "We Buy Houses Any Condition in California | Inland Empire Home Source";
var meta_description = "Facing foreclosure, inherited a property, divorce, problem tenants, or major repairs? We buy houses in any situation across the Inland Empire. Call (909) 202-6006.";
%>
<%- include('base', { title, meta_description, body: `

<!-- Header -->
<section class="pt-36 pb-16 bg-slate-950 text-white text-center px-4">
  <div class="max-w-3xl mx-auto">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-cyan-600/20 border border-cyan-500/30 text-cyan-400 text-[11px] font-black uppercase tracking-widest mb-6">
      <i class="fa-solid fa-house-circle-check text-xs"></i> Any Condition. Any Situation.
    </div>
    <h1 class="text-5xl md:text-6xl font-serif font-black tracking-tighter mb-6 uppercase">
      We Buy Houses <span class="text-cyan-400">Any Condition</span>
    </h1>
    <p class="text-slate-300 text-lg font-medium leading-relaxed mb-6">
      Whatever situation brought you here — we've seen it before, and we have a solution. Select your situation below to learn how we can help.
    </p>
  </div>
</section>

<!-- Situation Nav Chips -->
<section class="py-8 bg-white border-b border-slate-100 sticky top-16 z-40 shadow-sm">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap justify-center gap-2">
      ${situations.map(sit => `
      <a href="#${sit.id}" class="px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full text-xs font-black uppercase tracking-widest text-slate-600 hover:bg-cyan-600 hover:text-white hover:border-cyan-500 transition-all">
        ${sit.label}
      </a>
      `).join('')}
    </div>
  </div>
</section>

<!-- Situations -->
<div class="bg-white">
  ${situations.map((sit, index) => `
  <section id="${sit.id}" class="py-24 ${index % 2 === 1 ? 'bg-slate-50' : 'bg-white'} border-b border-slate-100">
    <div class="max-w-4xl mx-auto px-4">

      <div class="flex items-start gap-6 mb-10">
        <div class="w-14 h-14 bg-cyan-600/10 rounded-2xl flex items-center justify-center flex-shrink-0 mt-1">
          <i class="fa-solid fa-${sit.icon} text-2xl text-cyan-600"></i>
        </div>
        <div>
          <div class="text-xs font-black text-cyan-600 uppercase tracking-widest mb-2">${sit.label}</div>
          <h2 class="text-3xl md:text-4xl font-serif font-black tracking-tighter text-slate-900 uppercase leading-tight">
            ${sit.headline}
          </h2>
        </div>
      </div>

      <div class="space-y-5 mb-10">
        ${sit.body.map(paragraph => `
        <p class="text-slate-600 text-lg leading-relaxed font-medium">${paragraph}</p>
        `).join('')}
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href="tel:9092026006" class="inline-flex items-center gap-3 bg-cyan-600 hover:bg-cyan-700 text-white font-black px-8 py-4 rounded-full transition-colors">
          <i class="fa-solid fa-phone"></i> ${sit.cta}
        </a>
        <a href="tel:9092026006" class="text-slate-500 font-black text-sm hover:text-cyan-600 transition-colors">
          (909) 202-6006 — Call Anytime
        </a>
      </div>
    </div>
  </section>
  `).join('')}
</div>

<!-- CTA -->
<section class="py-20 bg-slate-950 text-white text-center px-4">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-4xl font-serif font-black tracking-tighter uppercase mb-4">
      Ready to Move Forward? <span class="text-cyan-400">Call Us Today.</span>
    </h2>
    <p class="text-slate-400 font-medium mb-8">
      Whatever your situation, the first step is a free, no-pressure conversation. We're available 7 days a week.
    </p>
    <a href="tel:9092026006" class="inline-flex items-center gap-3 bg-cyan-600 hover:bg-cyan-500 text-white text-lg font-black px-10 py-5 rounded-full transition-all shadow-2xl shadow-cyan-600/30">
      <i class="fa-solid fa-phone"></i> (909) 202-6006
    </a>
  </div>
</section>

` }) %>
