<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%- typeof meta_description !== 'undefined' ? meta_description : 'Inland Empire Home Source buys houses fast for cash throughout the Inland Empire, CA. No repairs, no fees, close in 7 days. Call (909) 202-6006.' %>" />
  <title><%- typeof title !== 'undefined' ? title : 'Inland Empire Home Source | Cash Home Buyers' %></title>

  <!-- Tailwind CSS Play CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'serif': ['"Playfair Display"', 'Georgia', 'serif'],
          },
          colors: {
            cyan: {
              50: '#ecfeff', 100: '#cffafe', 200: '#a5f3fc',
              300: '#67e8f9', 400: '#22d3ee', 500: '#06b6d4',
              600: '#0891b2', 700: '#0e7490', 800: '#155e75', 900: '#164e63',
            }
          }
        }
      }
    }
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&display=swap" rel="stylesheet" />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <!-- Custom styles -->
  <link rel="stylesheet" href="/css/style.css" />

  <%- typeof head_extra !== 'undefined' ? head_extra : '' %>
</head>
<body class="bg-white text-slate-900 font-sans">

  <!-- ── NAV ──────────────────────────────────────────────────────────────── -->
  <nav class="fixed top-0 inset-x-0 z-50 nav-blur border-b border-slate-200/80 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 bg-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 shadow-md group-hover:bg-cyan-700 transition-colors">
            <i class="fa-solid fa-house text-white text-sm"></i>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-black text-slate-900 text-[13px] uppercase tracking-tight">Inland Empire</span>
            <span class="font-black text-cyan-600 text-[11px] uppercase tracking-widest">Home Source</span>
          </div>
        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden md:flex items-center gap-1">
          <a href="/" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest transition-colors hover:text-cyan-600 <%- active === 'home' ? 'text-cyan-600' : 'text-slate-700' %>">Home</a>
          <a href="/cities" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest transition-colors hover:text-cyan-600 <%- active === 'cities' ? 'text-cyan-600' : 'text-slate-700' %>">Cities</a>
          <a href="/#why-us" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 transition-colors">Why Us</a>
          <a href="/#how-it-works" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 transition-colors">Our Process</a>
          <a href="/#faqs" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 transition-colors">FAQs</a>
          <a href="/blog" class="px-3 py-2 text-[12px] font-black uppercase tracking-widest transition-colors hover:text-cyan-600 <%- active === 'blog' ? 'text-cyan-600' : 'text-slate-700' %>">Blog</a>
          <a href="/contact" class="ml-2 px-4 py-2 bg-cyan-600 text-white text-[12px] font-black uppercase tracking-widest rounded-lg hover:bg-cyan-700 transition-colors <%- active === 'contact' ? 'ring-2 ring-cyan-400' : '' %>">Contact Us</a>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
          <i class="fa-solid fa-bars text-sm"></i>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-1 border-t border-slate-100 mt-2 pt-3">
        <a href="/" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors <%- active === 'home' ? 'text-cyan-600' : 'text-slate-700' %>">Home</a>
        <a href="/cities" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors <%- active === 'cities' ? 'text-cyan-600' : 'text-slate-700' %>">Cities</a>
        <a href="/#why-us" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors">Why Us</a>
        <a href="/#how-it-works" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors">Our Process</a>
        <a href="/#faqs" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest text-slate-700 hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors">FAQs</a>
        <a href="/blog" class="block px-3 py-2 text-[12px] font-black uppercase tracking-widest hover:text-cyan-600 hover:bg-slate-50 rounded-lg transition-colors <%- active === 'blog' ? 'text-cyan-600' : 'text-slate-700' %>">Blog</a>
        <a href="/contact" class="block mt-2 px-4 py-2.5 bg-cyan-600 text-white text-[12px] font-black uppercase tracking-widest text-center rounded-lg hover:bg-cyan-700 transition-colors">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- ── PAGE CONTENT ──────────────────────────────────────────────────────── -->
  <%- body %>

  <!-- ── FOOTER ────────────────────────────────────────────────────────────── -->
  <footer class="bg-slate-950 text-slate-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

        <!-- Our Mission -->
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <div class="w-8 h-8 bg-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-house text-white text-sm"></i>
            </div>
            <div class="flex flex-col leading-none">
              <span class="font-black text-white text-[13px] uppercase tracking-tight">Inland Empire</span>
              <span class="font-black text-cyan-400 text-[11px] uppercase tracking-widest">Home Source</span>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed font-medium mb-4">
            We are a locally owned and family-operated cash home buying company serving the Inland Empire since 2004. We are <strong class="text-white">not</strong> a national hedge fund or iBuyer — we are real people investing in the communities we live in.
          </p>
          <a href="tel:9092026006" class="inline-flex items-center gap-2 text-cyan-400 font-black text-sm hover:text-cyan-300 transition-colors">
            <i class="fa-solid fa-phone"></i> (909) 202-6006
          </a>
        </div>

        <!-- Cities We Serve -->
        <div>
          <h3 class="text-white font-black uppercase tracking-widest text-xs mb-5 pb-2 border-b border-slate-800">Cities We Serve</h3>
          <ul class="space-y-2">
            <% cities.forEach(function(city) { %>
            <li>
              <a href="/sell-my-house-fast-<%- city.slug %>" class="text-slate-400 text-sm font-medium hover:text-cyan-400 transition-colors flex items-center gap-2">
                <i class="fa-solid fa-location-dot text-cyan-700 text-xs w-3"></i>
                <%- city.name %>, CA
              </a>
            </li>
            <% }); %>
          </ul>
        </div>

        <!-- Legal Disclaimer -->
        <div>
          <h3 class="text-white font-black uppercase tracking-widest text-xs mb-5 pb-2 border-b border-slate-800">Legal Disclaimer</h3>
          <p class="text-slate-500 text-xs leading-relaxed mb-4">
            Inland Empire Home Source is a private real estate investment company. We are not licensed real estate agents or brokers and do not represent buyers or sellers as a broker. The cash offers we make are our own investment decisions. Offers are subject to property inspection and due diligence. There is no obligation to accept any offer.
          </p>
          <p class="text-slate-500 text-xs leading-relaxed mb-5">
            &copy; <%- current_year %> Inland Empire Home Source. All rights reserved. Serving Riverside County &amp; San Bernardino County, California.
          </p>
          <a href="/privacy-policy" class="text-xs text-slate-400 underline hover:text-cyan-400 transition-colors">Privacy Policy</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- ── SCRIPTS ───────────────────────────────────────────────────────────── -->
  <script src="/js/main.js"></script>
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
